{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "mocha"]
  },
  "files": ["globals.d.ts"],
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
